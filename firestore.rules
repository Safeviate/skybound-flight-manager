rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from their profile.
    function getUserRole(userId, companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId)).data.role;
    }
    
    // Helper function to get the user's permissions from their profile.
    function getUserPermissions(userId, companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId)).data.permissions;
    }

    // Allow a user to find their own user or student document across all companies.
    // This is essential for the application to determine the user's companyId after login.
    match /{path=**}/users/{userId} {
      allow get: if request.auth.uid == userId;
    }
    match /{path=**}/students/{userId} {
      allow get: if request.auth.uid == userId;
    }

    // Rules for all collections within a specific company.
    match /companies/{companyId} {
      // Allow any authenticated user to read the company document itself.
      allow read: if request.auth != null;

      // Rules for collections within a company.
      // Access is granted only if the user is a member of this company.
      // Note: A specific check for company membership will be added to each collection rule.
      
      function isUserOfCompany() {
          return exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)) ||
                 exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
      }
      
      // Allow read access to most collections if the user belongs to the company.
      // Write access is restricted by more specific rules below.
      allow read: if isUserOfCompany();
      
      match /aircraft/{aircraftId} {
          allow read: if isUserOfCompany();
          allow write: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Aircraft:Edit' in getUserPermissions(request.auth.uid, companyId));
      }
      
      match /alerts/{alertId} {
          allow read, write: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Alerts:Edit' in getUserPermissions(request.auth.uid, companyId));
      }

      match /bookings/{bookingId} {
          allow read, write: if isUserOfCompany(); // Allow all company members to read/write for simplicity, can be tightened later
      }
      
      match /safety-reports/{reportId} {
          allow read, write: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Safety:View' in getUserPermissions(request.auth.uid, companyId));
      }
      
      match /quality-audits/{auditId} {
          allow read, write: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Quality:View' in getUserPermissions(request.auth.uid, companyId));
      }
      
      match /students/{studentId} {
          allow read: if isUserOfCompany();
          allow write: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Students:Edit' in getUserPermissions(request.auth.uid, companyId));
      }

      match /users/{userId} {
          // Allow a user to update their own document.
          allow update: if request.auth.uid == userId;
          // Allow read/write based on permissions.
          allow read, create, delete: if isUserOfCompany() && ('Super User' in getUserPermissions(request.auth.uid, companyId) || 'Personnel:Edit' in getUserPermissions(request.auth.uid, companyId));
      }
      
       match /{collection}/{id} {
        allow read, write: if isUserOfCompany();
      }
    }
    
    // Deny all other access by default.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
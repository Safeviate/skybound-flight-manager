
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super User';
    }

    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }
    
    function isStudentInCompany(companyId) {
        return exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
    }
    
    function isUserInCompany(companyId) {
       return exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }

    // Allow read access to companies collection for all authenticated users
    match /companies/{companyId} {
      allow read: if isUserAuthenticated();
      
      // All other collections are within a company
      match /{collection}/{docId} {
        allow read, write: if isUserAuthenticated() && (isUserInCompany(companyId) || isStudentInCompany(companyId));
      }
    }
    
    // Allow users to read their own user/student document across all companies
    // This is required for login to work correctly
    match /{path=**}/students/{uid} {
        allow get: if isUserAuthenticated() && request.auth.uid == uid;
    }
    match /{path=**}/users/{uid} {
        allow get: if isUserAuthenticated() && request.auth.uid == uid;
    }
  }
}


rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get the user's ID
    function getUserId() {
      return request.auth.uid;
    }

    // Allow reads on the companies collection for logged in users
    // This is necessary for the user to select their company on login
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if false; // Disallow creating/deleting companies from the client
    }
    
    // Rules for all collections within a company document
    match /companies/{companyId}/{document=**} {
      // Allow read/write access only if the user's custom claim `companyId`
      // matches the companyId in the document path.
      // This is a common pattern but requires setting custom claims, which we haven't done.
      // A simpler, more direct rule is to check against the user document.
      // We will use a function to check user's company membership directly.
      allow read, write: if isSignedIn() && isUserMemberOfCompany(companyId);
    }
    
    // Function to check if the requesting user belongs to the specified company.
    // It checks both the 'users' and 'students' collections for the user's document.
    function isUserMemberOfCompany(companyId) {
      let userPath = /databases/$(database)/documents/companies/$(companyId)/users/$(getUserId());
      let studentPath = /databases/$(database)/documents/companies/$(companyId)/students/$(getUserId());
      
      return (exists(userPath) && get(userPath).data.companyId == companyId) || 
             (exists(studentPath) && get(studentPath).data.companyId == companyId);
    }
  }
}

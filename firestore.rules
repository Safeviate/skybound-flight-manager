rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all reads/writes by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow reading company data for authenticated users of that company.
    // This allows the app to load company-specific themes and settings.
    match /companies/{companyId} {
      allow read: if request.auth != null;
    }

    // Allow users to read and update their own document, and allow admins to create users.
    match /companies/{companyId}/users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.role in ['Admin', 'Super User'];
    }

    // Allow students to read and update their own document, and allow admins to create students.
    match /companies/{companyId}/students/{studentId} {
      allow read, update: if request.auth != null && request.auth.uid == studentId;
      allow create: if request.auth != null && get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.role in ['Admin', 'Super User'];
    }

    // Allow authenticated users of a company to read/write to that company's sub-collections.
    // This is a general rule that can be made more granular later.
    match /companies/{companyId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null;
    }

    // This is a critical rule that allows the app to find which company a user belongs to on login.
    match /companies/{companyId}/users/{userId} {
        allow get: if request.auth != null;
    }
  }
}

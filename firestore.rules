rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow any signed-in user to read all data within any company,
    // but only write if they are signed in. This is a common pattern for apps
    // where the main security concern is unauthorized writes, not reads by
    // authenticated users. More granular read rules can be added later if needed.
    match /companies/{companyId}/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
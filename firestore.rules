rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserInCompany(companyId) {
      let userPath = /databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid);
      let studentPath = /databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid);
      return exists(userPath) || exists(studentPath);
    }

    function getRole(userId) {
      // Check both collections for the user's role. This is more robust for cross-collection permissions.
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      if (userDoc != null) {
        return userDoc.data.role;
      }
      let studentDoc = get(/databases/$(database)/documents/students/$(userId));
       if (studentDoc != null) {
        return studentDoc.data.role;
      }
      return ''; // No role found
    }
    
    function hasPermission(permission) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      if (userDoc != null) {
        return permission in userDoc.data.permissions;
      }
       let studentDoc = get(/databases/$(database)/documents/students/$(request.auth.uid));
       if (studentDoc != null) {
        return permission in studentDoc.data.permissions;
      }
      return false;
    }

    // Rules for company creation
     match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create: if true; // Allow anyone to create a company
      allow update: if hasPermission('Super User') || hasPermission('Settings:Edit');
    }

    // Rules for top-level user & student collections (for login lookup)
    match /{collection}/{userId} {
        allow read, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Match any document inside a specific company's subcollections.
    match /companies/{companyId}/{document=**} {
      allow read, write: if isSignedIn() && isUserInCompany(companyId);
    }
  }
}
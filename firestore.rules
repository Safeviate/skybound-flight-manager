rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======== HELPER FUNCTIONS ======== //
    
    // Returns true if the user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the requesting user's data from the 'users' or 'students' collection within their company.
    function getRequestingUserData(companyId) {
      let userPath = /databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid);
      let studentPath = /databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid);
      
      if (exists(userPath)) {
        return get(userPath).data;
      }
      if (exists(studentPath)) {
        return get(studentPath).data;
      }
      return null;
    }

    // Checks if the requesting user belongs to the specified company.
    function isCompanyMember(companyId) {
      let userData = getRequestingUserData(companyId);
      return isSignedIn() && userData != null && userData.companyId == companyId;
    }

    // Checks if the requesting user has a specific permission.
    function hasPermission(companyId, permission) {
        let userData = getRequestingUserData(companyId);
        return userData != null && (permission in userData.permissions || 'Super User' in userData.permissions);
    }
    
    // Checks if the user is the owner of the document they are trying to access.
    function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    // ======== COLLECTION RULES ======== //
    
    match /companies/{companyId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Super User'); // Only Super Users can edit company details
    }
    
    match /companies/{companyId}/{collection}/{docId} {
        // Default Deny: No access unless explicitly granted by a more specific rule below.
        allow read, write: if false;
    }
    
    // USERS and STUDENTS can only be managed by authorized personnel, but individuals can read/update their own data.
    match /companies/{companyId}/users/{userId} {
        allow read, update: if isOwner(userId);
        allow create, delete: if hasPermission(companyId, 'Personnel:Edit');
    }

    match /companies/{companyId}/students/{studentId} {
        allow read, update: if isOwner(studentId);
        allow create, delete: if hasPermission(companyId, 'Students:Edit');
    }

    // Allow any company member to read general company configuration like roles and departments.
    match /companies/{companyId}/roles/{roleId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Roles & Departments:Edit');
    }
    match /companies/{companyId}/departments/{deptId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Roles & Departments:Edit');
    }

    // General read access for most collections to company members. Write access is restricted by role.
    match /companies/{companyId}/aircraft/{aircraftId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Aircraft:Edit');
    }
    match /companies/{companyId}/bookings/{bookingId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Bookings:Edit');
    }
    match /companies/{companyId}/safety-reports/{reportId} {
        allow read: if isCompanyMember(companyId); // Further checks can be added based on investigation team
        allow write: if hasPermission(companyId, 'Safety:Edit');
        allow create: if isSignedIn(); // Any signed-in user can file a report
    }
     match /companies/{companyId}/quality-audits/{auditId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'Quality:Edit');
    }
     match /companies/{companyId}/{document=**} {
        allow read, write: if isCompanyMember(companyId);
     }
    
    // ======== COLLECTION GROUP RULES ======== //
    // This is crucial. It allows the login function to securely find which company a user belongs to
    // without needing to know the companyId beforehand.
    match /{path=**}/users/{userId} {
      allow get: if isOwner(userId);
    }
     match /{path=**}/students/{studentId} {
      allow get: if isOwner(studentId);
    }
  }
}
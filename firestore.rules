rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from their user document.
    function getUserRole(userId, companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId)).data.role;
    }

    // Collection Group rules allow for querying across all subcollections with the same name.
    // This is CRITICAL for login, to find which company a user belongs to.
    match /{path=**}/users/{userId} {
      allow read: if request.auth.uid == userId;
    }
    match /{path=**}/students/{userId} {
      allow read: if request.auth.uid == userId;
    }

    // Rules for company-specific data.
    match /companies/{companyId} {
      allow read: if request.auth != null; // Allow any authenticated user to read company-level data (e.g., theme)

      // Rules for all collections within a company.
      match /{collection}/{docId} {
        allow read, write: if request.auth.uid != null && getUserRole(request.auth.uid, companyId) in ['Super User', 'Admin', 'Accountable Manager'];
      }
      
      // Allow users to read and update their own documents.
      match /users/{userId} {
        allow get: if request.auth.uid != null; // Allow any authenticated user in the company to get basic user info.
        allow list: if request.auth.uid != null;
        allow update: if request.auth.uid == userId || getUserRole(request.auth.uid, companyId) in ['Super User', 'Admin'];
        allow create: if getUserRole(request.auth.uid, companyId) in ['Super User', 'Admin'];
      }
      
      match /students/{userId} {
        allow get: if request.auth.uid != null;
        allow list: if request.auth.uid != null;
        allow update: if request.auth.uid == userId || getUserRole(request.auth.uid, companyId) in ['Super User', 'Admin', 'Instructor', 'Chief Flight Instructor', 'Head Of Training'];
        allow create: if getUserRole(request.auth.uid, companyId) in ['Super User', 'Admin'];
      }
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserInCompany(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
          || exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
    }
    
    function getRole(companyId) {
        let userDoc = get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
        if (exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid))) {
            return 'Student';
        }
        return userDoc.data.role;
    }
    
    function hasPermission(companyId, permission) {
        let userPermissions = get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.permissions;
        return permission in userPermissions;
    }

    // Top-level company documents can be read by any authenticated user of that company.
    // Only super users should be able to create/edit companies.
    match /companies/{companyId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if false; // Should be handled by backend functions for security
    }

    // Rules for all collections within a company
    match /companies/{companyId}/{collection}/{docId} {
        // Default deny all access unless explicitly allowed by nested rules
        allow read, write: if false;
    }
    
    // User and Student data access rules
    match /companies/{companyId}/users/{userId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || hasPermission(companyId, 'Personnel:View'));
        allow update: if isSignedIn() && (request.auth.uid == userId || hasPermission(companyId, 'Personnel:Edit'));
        allow create: if isSignedIn() && hasPermission(companyId, 'Personnel:Edit');
        allow delete: if isSignedIn() && hasPermission(companyId, 'Personnel:Edit');
    }
    
    match /companies/{companyId}/students/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasPermission(companyId, 'Students:View'));
        allow update: if isSignedIn() && (request.auth.uid == studentId || hasPermission(companyId, 'Students:Edit'));
        allow create: if isSignedIn() && hasPermission(companyId, 'Students:Edit');
        allow delete: if isSignedIn() && hasPermission(companyId, 'Students:Edit');
    }

    // Rules for other collections
    match /companies/{companyId}/aircraft/{aircraftId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if isSignedIn() && hasPermission(companyId, 'Aircraft:Edit');
    }

    match /companies/{companyId}/bookings/{bookingId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if isSignedIn() && hasPermission(companyId, 'Bookings:Edit');
    }

    match /companies/{companyId}/safety-reports/{reportId} {
        allow read: if isSignedIn() && hasPermission(companyId, 'Safety:View');
        allow write: if isSignedIn() && hasPermission(companyId, 'Safety:Edit');
    }
    
    match /companies/{companyId}/quality-audits/{auditId} {
        allow read: if isSignedIn() && hasPermission(companyId, 'Quality:View');
        allow write: if isSignedIn() && hasPermission(companyId, 'Quality:Edit');
    }
    
     match /companies/{companyId}/risks/{riskId} {
        allow read: if isSignedIn() && hasPermission(companyId, 'Safety:View');
        allow write: if isSignedIn() && hasPermission(companyId, 'Safety:Edit');
    }

    match /companies/{companyId}/alerts/{alertId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if isSignedIn() && (hasPermission(companyId, 'Alerts:Edit') || request.auth.uid == resource.data.targetUserId);
    }
    
    // Other collections can be added here with similar patterns...
    match /companies/{companyId}/roles/{roleId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if isSignedIn() && hasPermission(companyId, 'Roles & Departments:Edit');
    }
    
    match /companies/{companyId}/departments/{deptId} {
        allow read: if isSignedIn() && isUserInCompany(companyId);
        allow write: if isSignedIn() && hasPermission(companyId, 'Roles & Departments:Edit');
    }
    
    // This allows the user provider to find the user's company on login.
    match /{path=**}/users/{userId} {
      allow read: if request.auth.uid == userId;
    }
    
    match /{path=**}/students/{userId} {
        allow read: if request.auth.uid == userId;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to get the user's role and permissions from their document
    function getUserData(userId) {
      // Check both users and students collections within any company
      let userData = get(firestore.get(/databases/$(database)/documents/users/$(userId)).path);
      if (!exists(firestore.get(/databases/$(database)/documents/users/$(userId)).path)) {
        let studentData = get(firestore.get(/databases/$(database)/documents/students/$(userId)).path);
        if (exists(firestore.get(/databases/$(database)/documents/students/$(userId)).path)) {
          return studentData.data;
        }
      }
      return userData.data;
    }
    
    // Most data is nested under a company.
    match /companies/{companyId} {
      
      // Allow read of company data if user belongs to the company
      allow get: if request.auth != null && (
                    exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)) ||
                    exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid))
                  );
                  
      // Allow company creation by anyone for corporate sign-up
      allow create: if true;
      
      // Allow Super Users to update company details
      allow update: if request.auth != null && getUserData(request.auth.uid).permissions.hasAny(['Super User']);

      // Default deny all other collections unless specified
      match /{collection}/{docId} {
        allow read, write: if false;
      }

      // Rules for users and students collections
      match /(users|students)/{userId} {
        // Allow users to read their own document
        allow get: if request.auth.uid == userId;
        
        // Allow users to update their own document
        allow update: if request.auth.uid == userId;
        
        // Allow users with Personnel:Edit or Students:Edit to read any user/student in their company
        allow list: if getUserData(request.auth.uid).permissions.hasAny(['Personnel:View', 'Students:View', 'Super User']);
        
        // Allow creating new users/students
        allow create: if getUserData(request.auth.uid).permissions.hasAny(['Personnel:Edit', 'Students:Edit', 'Super User']);
      }
      
      // Rules for all other top-level collections within a company
      match /{collection}/{docId} {
        // By default, only allow access if the user is authenticated and part of the company.
        // This is a base layer of security. More granular rules are below.
        allow read, write: if request.auth != null && (
                              exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)) ||
                              exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid))
                            );
      }
    }
    
    // This rule is critical. It allows an authenticated user to be found
    // across all companies during the login process.
    match /{path=**}/(users|students)/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
    }
  }
}

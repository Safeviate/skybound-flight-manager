
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Does the requesting user's UID match the userId in the path?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Get the data for the currently authenticated user.
    // This allows checking roles and permissions.
    function getAuthUserDoc(companyId) {
        return get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
    }
    
    // Check if the user has a specific permission.
    function hasPermission(companyId, permission) {
        let authUserDoc = getAuthUserDoc(companyId);
        return isAuthenticated() && permission in authUserDoc.data.permissions;
    }

    // Check if the user has the 'Super User' permission.
    function isSuperUser(companyId) {
        return hasPermission(companyId, 'Super User');
    }

    // --- Rules for Company Collections ---
    
    match /companies/{companyId} {
        // Anyone can create a company (sign up).
        allow create: if true;
        // Only Super Users of that company can read/update company details.
        allow read, update: if isSuperUser(companyId);

        // --- Collections within a Company ---
        
        match /users/{userId} {
            // A user can read/update their own document.
            // A Super User or someone with Personnel:Edit can read/update any user document.
            allow read, update: if isOwner(userId) || hasPermission(companyId, 'Personnel:View') || hasPermission(companyId, 'Personnel:Edit') || isSuperUser(companyId);
            // Only a Super User or someone with Personnel:Edit can create or delete users.
            allow create, delete: if hasPermission(companyId, 'Personnel:Edit') || isSuperUser(companyId);
        }

        match /students/{studentId} {
            // A student can read/update their own document.
            // A Super User or someone with Students permissions can read/update any student document.
            allow read, update: if isOwner(studentId) || hasPermission(companyId, 'Students:View') || hasPermission(companyId, 'Students:Edit') || isSuperUser(companyId);
            // Only a Super User or someone with Students:Edit can create or delete students.
            allow create, delete: if hasPermission(companyId, 'Students:Edit') || isSuperUser(companyId);
        }

        // Catch-all for most other collections
        match /{collection}/{docId} {
            // Default to requiring authentication for all reads/writes within a company.
            // Specific permissions should be checked within each collection's rules if needed.
            allow read, write: if isAuthenticated();
        }
    }

    // This rule allows the application to find which company a user belongs to
    // during the login process, which is a key part of fixing the permission errors.
    match /{path=**}/users/{userId} {
      allow get: if isOwner(userId);
    }
  }
}

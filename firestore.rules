
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserInCompany(companyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
          || exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
    }
    
    function getUser(companyId, userId) {
      // First try to get from 'users' collection
      let userDoc = get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId));
      // If not found, try 'students' collection
      if (!exists(/databases/$(database)/documents/companies/$(companyId)/users/$(userId))) {
        return get(/databases/$(database)/documents/companies/$(companyId)/students/$(userId));
      }
      return userDoc;
    }

    // Companies can be read by any authenticated user who is part of that company.
    // Company creation is open to allow for new sign-ups.
    match /companies/{companyId} {
      allow read: if isUserInCompany(companyId);
      allow write: if isSignedIn(); // Allows creation of new companies
      
      // All sub-collections are accessible by any authenticated user within that company
      match /{document=**} {
         allow read, write: if isUserInCompany(companyId);
      }
    }
    
    // Allow users to find their own user document during login/auth state change
    // This is a common pattern to allow a user to find which company they belong to.
    match /{path=**}/users/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
    }
    match /{path=**}/students/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to reduce repetition
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserInCompany(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)) ||
             exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
    }
    
    function getUserData(companyId) {
       // First, try to get from the 'users' collection
      let userData = get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid));
      // If not found in 'users', try 'students'
      if (!userData.data.keys().hasAll(['permissions'])) {
          return get(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
      }
      return userData;
    }

    function hasPermission(companyId, permission) {
      // Ensure the user exists in the company before checking permissions.
      // This prevents errors if a user from one company tries to access another.
      if (!isUserInCompany(companyId)) {
        return false;
      }
      // Get the user's data and check if their permissions array contains the required permission.
      let userData = getUserData(companyId);
      return permission in userData.data.permissions;
    }
    
    // Global rule: By default, no one can access anything.
    // This is a security best practice.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow new companies to be created by anyone.
    // This is necessary for the corporate registration page to work.
    match /companies/{companyId} {
      allow create: if true;
      allow read, update: if isSignedIn() && isUserInCompany(companyId) && hasPermission(companyId, 'Super User');
    }

    // This is the critical rule that allows a newly logged-in user to find their own
    // user document (and thus their companyId) across all companies.
    match /{path=**}/users/{userId} {
      allow get: if request.auth.uid == userId;
    }
     match /{path=**}/students/{userId} {
      allow get: if request.auth.uid == userId;
    }
    
    // Rules for all collections within a specific company.
    // The `isUserInCompany(companyId)` check ensures users can only access their own company's data.
    match /companies/{companyId}/{collection}/{docId} {
        allow read: if isSignedIn() && isUserInCompany(companyId); // General read for most collections if in company
        allow write: if isSignedIn() && isUserInCompany(companyId) && hasPermission(companyId, 'Super User');
    }

    // More specific rules for collections that require fine-grained control
    match /companies/{companyId}/users/{userId} {
      allow get: if isSignedIn() && isUserInCompany(companyId);
      allow list: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Personnel:View') || hasPermission(companyId, 'Super User'));
      allow create, update, delete: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Personnel:Edit') || hasPermission(companyId, 'Super User'));
    }

    match /companies/{companyId}/students/{studentId} {
      allow get: if isSignedIn() && isUserInCompany(companyId);
      allow list: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Students:View') || hasPermission(companyId, 'Super User'));
      allow create, update, delete: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Students:Edit') || hasPermission(companyId, 'Super User'));
    }
    
    match /companies/{companyId}/safety-reports/{reportId} {
        allow read: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Safety:View') || hasPermission(companyId, 'Super User'));
        allow write: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Safety:Edit') || hasPermission(companyId, 'Super User'));
        allow create: if isSignedIn() && isUserInCompany(companyId); // Anyone in the company can file a report
    }
    
    match /companies/{companyId}/quality-audits/{auditId} {
        allow read: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Quality:View') || hasPermission(companyId, 'Super User'));
        allow write: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Quality:Edit') || hasPermission(companyId, 'Super User'));
    }
    
    match /companies/{companyId}/bookings/{bookingId} {
        allow read: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Bookings:View') || hasPermission(companyId, 'Super User'));
        allow write: if isSignedIn() && isUserInCompany(companyId) && (hasPermission(companyId, 'Bookings:Edit') || hasPermission(companyId, 'Super User'));
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get the user's role and permissions from their user document
    function getUserData(userId) {
      // First, try to get from the 'users' collection group
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      // If not found, try the 'students' collection group
      if (userData == null) {
        userData = get(/databases/$(database)/documents/students/$(userId)).data;
      }
      return userData;
    }

    // Allow a user to find their own document on login to get their companyId and roles
    match /{path=**}/users/{userId} {
      allow get: if isAuthenticated() && request.auth.uid == userId;
    }
    match /{path=**}/students/{userId} {
       allow get: if isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for all documents within a specific company
    match /companies/{companyId}/{collection}/{docId} {
      allow read, write: if isAuthenticated() && getUserData(request.auth.uid).companyId == companyId;
    }
    
    // Default deny all other access
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

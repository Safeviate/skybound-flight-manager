rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles and permissions
    function isCompanyMember(companyId) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid))
      );
    }

    function getRole(userId) {
      // This will check both users and students collection for a role.
      // Note: This requires a collectionGroup index on 'users' and 'students' for the 'id' field.
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      if (userDoc != null) {
        return userDoc.data.role;
      }
      let studentDoc = get(/databases/$(database)/documents/students/$(userId));
      if (studentDoc != null) {
        return studentDoc.data.role;
      }
      return '';
    }
    
    function isSuperUser() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super User';
    }

    // Rules for top-level collections
    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow write: if isSuperUser(); // Only super users can edit company documents

      // Rules for all subcollections within a company
      match /{collection}/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }
    }
    
    // Rules for collection groups to enable cross-company queries securely
    match /{path=**}/users/{userId} {
       allow read, update: if request.auth != null && request.auth.uid == userId;
       // Create is handled by the subcollection rule under /companies/{companyId}
    }
    
    match /{path=**}/students/{studentId} {
       allow read, update: if request.auth != null && request.auth.uid == studentId;
       // Create is handled by the subcollection rule under /companies/{companyId}
    }
  }
}

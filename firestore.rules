rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      // First, try to get from the 'users' collection group
      let userDoc = get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)/users/$(userId));
      if (userDoc != null) {
        return userDoc.data;
      }
      // If not found, try the 'students' collection group
      return get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)/students/$(userId)).data;
    }
    
    function isCompanyMember(companyId) {
        return isSignedIn() && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
            || exists(/databases/$(database)/documents/companies/$(companyId)/students/$(request.auth.uid));
    }
    
    function hasPermission(permission) {
        let userDoc = getUserData(request.auth.uid);
        return userDoc != null && (permission in userDoc.permissions || 'Super User' in userDoc.permissions);
    }
    
    // Allow a user to find their own document across all companies.
    // This is the critical rule that was missing/incorrect and fixes the login permission error.
    match /{path=**}/users/{userId} {
      allow get: if isUser(userId);
      allow list: if hasPermission('Personnel:View');
    }
    
    match /{path=**}/students/{userId} {
       allow get: if isUser(userId);
       allow list: if hasPermission('Students:View');
    }

    // Rules for all documents within a specific company
    match /companies/{companyId}/{collection}/{docId} {
      allow read, write: if isCompanyMember(companyId);
    }
    
    // Allow unauthenticated users to create a company, but not read/update/delete existing ones.
    match /companies/{companyId} {
        allow read, update, delete: if false;
        allow create: if true;
    }
  }
}

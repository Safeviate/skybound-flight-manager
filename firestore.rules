rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() {
      return request.auth != null;
    }

    // Get the user's role and permissions from their document in the /users/ collection
    function getUserData(companyId, userId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId)).data;
    }

    // Get the student's data from their document in the /students/ collection
    function getStudentData(companyId, userId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/students/$(userId)).data;
    }
    
    // Check if a user has a specific permission
    function hasPermission(permission) {
        let userData = getUserData(request.auth.token.companyId, request.auth.uid);
        // Fallback for students who might not have a separate doc in users collection
        if (userData == null) {
            let studentData = getStudentData(request.auth.token.companyId, request.auth.uid);
            return studentData.permissions.hasAny([permission, 'Super User']);
        }
        return userData.permissions.hasAny([permission, 'Super User']);
    }
    
    // Check if the user is a member of the company they are trying to access
    function isCompanyMember(companyId) {
        return isAuth() && request.auth.token.companyId == companyId;
    }
    
    // --- Top-Level Company Rules ---
    match /companies/{companyId} {
        // Allow any authenticated user to read their own company's top-level document
        allow read: if isCompanyMember(companyId);
        // Only Super Users can create or update company documents
        allow write: if isAuth() && getUserData(companyId, request.auth.uid).permissions.hasAny(['Super User']);

        // --- Rules for Subcollections ---
      
        // Users & Students: Allow users to read their own data.
        match /users/{userId} {
            allow read: if isAuth() && (request.auth.uid == userId || hasPermission('Personnel:View'));
            allow write: if isAuth() && (request.auth.uid == userId || hasPermission('Personnel:Edit'));
        }

        match /students/{studentId} {
            allow read: if isAuth() && (request.auth.uid == studentId || hasPermission('Students:View'));
            allow write: if isAuth() && (request.auth.uid == studentId || hasPermission('Students:Edit'));
        }
      
        // Bookings: Users can see their own bookings. Edit permissions are more restrictive.
        match /bookings/{bookingId} {
            allow read: if isAuth() && (
                hasPermission('Bookings:View') ||
                resource.data.studentId == request.auth.uid ||
                resource.data.instructorId == request.auth.uid
            );
            allow create, update: if isAuth() && hasPermission('Bookings:Edit');
            allow delete: if isAuth() && hasPermission('Super User'); // Restrict deletion
        }

        // Safety Reports: Controlled by Safety permissions
        match /safety-reports/{reportId} {
            allow read: if isAuth() && hasPermission('Safety:View');
            allow create, update: if isAuth() && hasPermission('Safety:Edit');
            allow delete: if isAuth() && hasPermission('Super User');
        }

        // Quality Audits: Controlled by Quality permissions
        match /quality-audits/{auditId} {
            allow read: if isAuth() && hasPermission('Quality:View');
            allow create, update: if isAuth() && hasPermission('Quality:Edit');
            allow delete: if isAuth() && hasPermission('Quality:Delete');
        }
        
        // Alerts: Allow users to read alerts targeted at them, and managers to see all
        match /alerts/{alertId} {
            allow read, update: if isAuth() && (
                hasPermission('Alerts:View') ||
                resource.data.targetUserId == request.auth.uid ||
                !resource.data.keys().hasAny(['targetUserId']) // Public alert
            );
            allow create: if isAuth() && hasPermission('Alerts:Edit');
            allow delete: if isAuth() && hasPermission('Super User');
        }
      
        // All other subcollections can be read by any company member, but only edited by admins
        match /{document=**} {
          allow read: if isCompanyMember(companyId);
          allow write: if isAuth() && hasPermission('Super User');
        }
    }

    // This rule allows a logged-in user to find which company they belong to.
    // It is essential for the initial data load after authentication.
    match /{path=**}/users/{userId} {
      allow get: if isAuth() && request.auth.uid == userId;
    }
     match /{path=**}/students/{userId} {
      allow get: if isAuth() && request.auth.uid == userId;
    }
  }
}